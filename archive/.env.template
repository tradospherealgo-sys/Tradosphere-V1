# ═══════════════════════════════════════════════════════════════════════════
# TRADOSPHERE ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# ANGEL ONE API CREDENTIALS
# Get these from: https://smartapi.angelbroking.com/
# ─────────────────────────────────────────────────────────────────────────
ANGEL_ONE_API_KEY=your_angel_one_api_key_here
ANGEL_ONE_API_SECRET=your_angel_one_api_secret_here
ANGEL_ONE_CLIENT_CODE=your_angel_one_client_code_here

# ─────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# For local development: sqlite:///tradosphere.db
# For PostgreSQL: postgresql://user:password@localhost:5432/tradosphere
# For Railway: postgresql://user:password@railway.app:5432/tradosphere
# ─────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///tradosphere.db

# ─────────────────────────────────────────────────────────────────────────
# FLASK CONFIGURATION
# Set to 'development' for local testing, 'production' for deployment
# ─────────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_SECRET_KEY=your_secret_key_change_this_in_production_12345

# ─────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=False

# ─────────────────────────────────────────────────────────────────────────
# DEPLOYMENT NOTES
# ─────────────────────────────────────────────────────────────────────────
# 1. Fill in Angel One API credentials from your broker account
# 2. Update DATABASE_URL if using PostgreSQL (Railway.app)
# 3. Generate a strong FLASK_SECRET_KEY for production (min 32 chars)
# 4. Set FLASK_ENV=production before deploying
# 5. Never commit .env file to version control (use .gitignore)
