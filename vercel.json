{
  "version": 2,
  "routes": [
    {
      "src": "/config.js",
      "dest": "/config.js",
      "headers": {
        "Cache-Control": "public, max-age=3600, must-revalidate",
        "Content-Type": "application/javascript"
      }
    },
    {
      "src": "/api/(.*)",
      "status": 404
    },
    {
      "src": "/(.*\\.(?:css|js|json|ico|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot))",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard_live.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
