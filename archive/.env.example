# ═══════════════════════════════════════════════════════════════════════════
# TRADOSPHERE ENVIRONMENT VARIABLES - EXAMPLE
# Copy this file to .env and fill in your actual values
# NEVER commit .env file with real credentials
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# FLASK APPLICATION CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_SECRET_KEY=your_strong_secret_key_here_min_32_chars_long

# ─────────────────────────────────────────────────────────────────────────
# ANGEL ONE API CREDENTIALS
# Get these from: https://smartapi.angelbroking.com/
# ─────────────────────────────────────────────────────────────────────────
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_CLIENT_CODE=your_client_code_here
ANGEL_ONE_PIN=your_pin_here
ANGEL_ONE_TOTP_SECRET=your_totp_secret_here

# ─────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# Current: SQLite (ephemeral, data lost on restart)
# For production: Use PostgreSQL with Railway
# ─────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///tradosphere.db

# Alternative for PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/tradosphere_db
